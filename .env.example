# ProofHold environment configuration
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# All vars must be prefixed with VITE_ to be exposed to the client bundle.

# Nimiq network: "main" or "test"
VITE_NIMIQ_NETWORK=test

# Custody address that holds buyer funds during a deal.
# Get one from https://wallet.nimiq.com — write down the 24 recovery words
# somewhere durable; this client-side var stores ONLY the public address.
VITE_PROOFHOLD_CUSTODY_NIM_ADDR=NQ00 0000 0000 0000 0000 0000 0000 0000 0000

# EVM chain to use for USDT payments.
# Common chain IDs: 137 = Polygon, 8453 = Base, 56 = BSC, 1 = Ethereum mainnet
VITE_USDT_CHAIN_ID=137

# USDT contract address on the chain above.
# Polygon USDT: 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# Base USDC (USDT not on Base): adjust as needed
VITE_USDT_CONTRACT_ADDR=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# USDT decimals (Polygon USDT = 6).
VITE_USDT_DECIMALS=6

# EVM custody address (where USDT is sent during a deal hold).
# Generate via MetaMask/your EVM wallet; never paste a private key here.
VITE_PROOFHOLD_CUSTODY_EVM_ADDR=0x0000000000000000000000000000000000000000
